# ============================================
# Trinity Pixels — AI Voice Receptionist SaaS
# ============================================

# -- Database (PostgreSQL via Docker) --
DATABASE_URL=postgresql://trinity:trinity_secret@localhost:5432/trinitypixels

# -- JWT --
JWT_SECRET=replace-with-a-strong-random-string-at-least-32-chars

# -- Backend --
BACKEND_PORT=4000
FRONTEND_URL=http://localhost:3000

# -- Razorpay --
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# -- Plivo --
PLIVO_AUTH_ID=your_plivo_auth_id
PLIVO_AUTH_TOKEN=your_plivo_auth_token

# -- n8n Webhook URLs (configured after n8n is running) --
N8N_POST_CALL_WEBHOOK=http://localhost:5678/webhook/post-call
N8N_ADMIN_ALERT_WEBHOOK=http://localhost:5678/webhook/admin-alert
